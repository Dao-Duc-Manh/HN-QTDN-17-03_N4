<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View for Contract Dashboard -->
    <record id="view_hop_dong_kanban" model="ir.ui.view">
        <field name="name">hop.dong.kanban</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <kanban default_group_by="trang_thai" class="o_kanban_small_column">
                <field name="so_hop_dong"/>
                <field name="ten_hop_dong"/>
                <field name="ngay_ky"/>
                <field name="ngay_bat_dau"/>
                <field name="ngay_ket_thuc"/>
                <field name="gia_tri_hop_dong"/>
                <field name="trang_thai"/>
                <field name="tinh_trang"/>
                <field name="id_khach_hang"/>
                <field name="nguoi_quan_ly"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="so_hop_dong"/> - <field name="ten_hop_dong"/></strong>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="id_khach_hang"/>
                                </div>
                                <div class="oe_kanban_bottom_left">
                                    <field name="ngay_ket_thuc"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="gia_tri_hop_dong"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="trang_thai" widget="label_selection" 
                                           options="{'classes': {'Hoàn thành': 'success', 'Quá hạn': 'danger', 'Sắp hết hạn': 'warning', 'Đang thực hiện': 'info', 'Hủy': 'secondary', 'Tạm dừng': 'muted'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Graph View for Contracts -->
    <record id="view_hop_dong_graph" model="ir.ui.view">
        <field name="name">hop.dong.graph</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <graph string="Thống kê hợp đồng" type="bar">
                <field name="trang_thai"/>
                <field name="gia_tri_hop_dong" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View for Contracts -->
    <record id="view_hop_dong_pivot" model="ir.ui.view">
        <field name="name">hop.dong.pivot</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích hợp đồng" display_quantity="true">
                <field name="trang_thai" type="row"/>
                <field name="ngay_ky" interval="month" type="col"/>
                <field name="gia_tri_hop_dong" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Calendar View for Contracts -->
    <record id="view_hop_dong_calendar" model="ir.ui.view">
        <field name="name">hop.dong.calendar</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <calendar string="Lịch hợp đồng" date_start="ngay_bat_dau" date_stop="ngay_ket_thuc" color="trang_thai" mode="month">
                <field name="ten_hop_dong"/>
                <field name="id_khach_hang"/>
            </calendar>
        </field>
    </record>

    <!-- Search View for Contracts Dashboard -->
    <record id="view_hop_dong_dashboard_search" model="ir.ui.view">
        <field name="name">hop.dong.dashboard.search</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm hợp đồng">
                <field name="so_hop_dong"/>
                <field name="ten_hop_dong"/>
                <field name="id_khach_hang"/>
                <field name="nguoi_quan_ly"/>
                <field name="trang_thai"/>
                <filter string="Hoàn thành" name="hoan_thanh" 
                        domain="[('trang_thai.ten_trang_thai', '=', 'Hoàn thành')]"/>
                <filter string="Đang thực hiện" name="dang_thuc_hien" 
                        domain="[('trang_thai.ten_trang_thai', '=', 'Đang thực hiện')]"/>
                <filter string="Sắp hết hạn" name="sap_het_han" 
                        domain="[('trang_thai.ten_trang_thai', '=', 'Sắp hết hạn')]"/>
                <filter string="Quá hạn" name="qua_han" 
                        domain="[('trang_thai.ten_trang_thai', '=', 'Quá hạn')]"/>
                <filter string="Hủy" name="huy" 
                        domain="[('trang_thai.ten_trang_thai', '=', 'Hủy')]"/>
                <separator/>
                <filter string="Của tôi" name="my_contracts" 
                        domain="[('nguoi_quan_ly', '=', uid)]"/>
                <filter string="Tháng này" name="this_month" 
                        domain="[('ngay_ky','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Trạng thái" name="group_by_trang_thai" 
                            context="{'group_by': 'trang_thai'}"/>
                    <filter string="Khách hàng" name="group_by_khach_hang" 
                            context="{'group_by': 'id_khach_hang'}"/>
                    <filter string="Người quản lý" name="group_by_nguoi_quan_ly" 
                            context="{'group_by': 'nguoi_quan_ly'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_hop_dong_dashboard" model="ir.actions.act_window">
        <field name="name">Bảng điều khiển Hợp đồng</field>
        <field name="res_model">hop_dong</field>
        <field name="view_mode">tree,kanban,graph,pivot,calendar,form</field>
        <field name="search_view_id" ref="view_hop_dong_dashboard_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có hợp đồng nào được tạo
            </p>
            <p>
                Tạo hợp đồng mới để quản lý và theo dõi tiến độ của chúng.
            </p>
        </field>
    </record>
</odoo>

