<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hop_dong_form" model="ir.ui.view">
            <field name="name">hop_dong.form</field>
            <field name="model">hop_dong</field>
            <field name="arch" type="xml">
                <form string="Quản lý Hợp đồng">
                    <sheet>
                        <div class="oe_title">
                            <h2 class="text-primary" style="font-size: 25px; font-weight: bold;">
                                Hợp đồng</h2>
                        </div>

                        <div class="card p-3 shadow-sm mb-3">
                            <group col="4">
                                <field name="so_hop_dong" class="o_form_required" />
                                <field name="ten_hop_dong" />
                                <field name="id_khach_hang" />
                                <field name="nguoi_quan_ly" />
                            </group>
                        </div>

                        <div class="card p-3 shadow-sm mb-3">
                            <group col="4">
                                <field name="ngay_ky" />
                                <field name="ngay_bat_dau" />
                                <field name="ngay_ket_thuc" />
                                <field name="gia_tri_hop_dong" />
                            </group>
                        </div>

                        <div class="card p-3 shadow-sm mb-3">
                            <group col="4">
                                <field name="tinh_trang" />
                                <field name="trang_thai" />
                            </group>
                        </div>

                        <div class="card p-3 shadow-sm mb-3">
                            <group col="4">
                                <field name="mo_ta" nolabel="1" colspan="4" />
                            </group>
                        </div>

                        <div class="card p-3 shadow-sm">
                            <h3 class="text-secondary">File đính kèm</h3>
                            <group col="4">
                                <field name="ten_tep" />
                                <field name="tep_dinh_kem" widget="binary" />
                            </group>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hop_dong_tree" model="ir.ui.view">
            <field name="name">hop_dong.tree</field>
            <field name="model">hop_dong</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="so_hop_dong" />
                    <field name="ten_hop_dong" />
                    <field name="id_khach_hang" />
                    <field name="ngay_ky" />
                    <field name="ngay_bat_dau" />
                    <field name="ngay_ket_thuc" />
                    <field name="gia_tri_hop_dong" />
                    <field name="trang_thai" />
                    <field name="tinh_trang" />
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="hop_dong_search">
            <field name="model">hop_dong</field>
            <field name="arch" type="xml">
                <search>
                    <field name="so_hop_dong" />
                    <field name="ten_hop_dong" />
                    <field name="id_khach_hang" />
                    <field name="nguoi_quan_ly" />
                    <field name="trang_thai" />
                    <filter string="Đang thực hiện" name="dang_thuc_hien" 
                            domain="[('tinh_trang', '=', 'dang_thuc_hien')]"/>
                    <filter string="Hoàn thành" name="hoan_thanh" 
                            domain="[('tinh_trang', '=', 'hoan_thanh')]"/>
                    <filter string="Hủy" name="huy" 
                            domain="[('tinh_trang', '=', 'huy')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Trạng thái" name="group_by_trang_thai" 
                                context="{'group_by': 'trang_thai'}"/>
                        <filter string="Khách hàng" name="group_by_khach_hang" 
                                context="{'group_by': 'id_khach_hang'}"/>
                        <filter string="Người quản lý" name="group_by_nguoi_quan_ly" 
                                context="{'group_by': 'nguoi_quan_ly'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hop_dong" model="ir.actions.act_window">
            <field name="name">Quản lý Hợp đồng</field>
            <field name="res_model">hop_dong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="hop_dong_search" />
        </record>
    </data>
</odoo>

